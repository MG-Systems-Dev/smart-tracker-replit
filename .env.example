# Google Drive Database Sync Configuration
# Copy this file to .env and fill in your values

# Path to your Google service account credentials JSON file
GOOGLE_CREDENTIALS=credentials/service-account.json

# Google Drive file ID for your database
# Find this in the URL when viewing the file: https://drive.google.com/file/d/FILE_ID_HERE/view
DRIVE_DB_FILE_ID=your-file-id-here

# Local database path (relative to project root)
DB_PATH=data/smart_tracker.db

# PostgreSQL connection (leave empty for local SQLite mode)
DATABASE_URL=
